<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!--  App-private Downloads (fallback)  -->
    <external-files-path
        name="app_downloads"
        path="Downloads/" />
    <files-path
        name="internal_downloads"
        path="Downloads/" />

    <!--  Public shared storage  -->
    <external-path
        name="public_downloads"
        path="Download/DC/" />
    <external-path
        name="public_movies"
        path="Movies/DC/" />
    <external-path
        name="public_music"
        path="Music/DC/" />

    <!--  Entire public external (broad fallback for open/share)  -->
    <external-path
        name="external_root"
        path="." />

    <cache-path
        name="cache"
        path="." />
</paths>
