<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer glow ring -->
    <path
        android:pathData="M54,54m-42,0a42,42 0,1 1,84 0a42,42 0,1 1,-84 0"
        android:fillAlpha="0.15">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="42">
                <item android:offset="0" android:color="#9C4DFF" />
                <item android:offset="1" android:color="#03DAC5" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Download arrow icon -->
    <path
        android:pathData="M54,28 L54,60 M42,50 L54,64 L66,50"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="@android:color/transparent" />

    <!-- Base line -->
    <path
        android:pathData="M38,72 L70,72"
        android:strokeColor="#03DAC5"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent" />
</vector>
